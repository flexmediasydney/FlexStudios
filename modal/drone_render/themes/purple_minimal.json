{
  "theme_name": "Purple Minimal",
  "version": "1.0",
  "inherits_from": null,

  "anchor_line": {
    "shape": "thin",
    "width_px": 3,
    "color": "#6B3E99",
    "opacity": 1.0,
    "min_length_px": 40,
    "max_length_px": 220,
    "flip_below_target_threshold_px": 80,
    "end_marker": {
      "shape": "circle",
      "size_px": 14,
      "fill_color": "#6B3E99",
      "stroke_color": "#FFFFFF",
      "stroke_width_px": 3
    }
  },

  "poi_label": {
    "shape": "rectangle",
    "corner_radius_px": 0,
    "fill": "#4A2A7A",
    "border": { "color": null, "width_px": 0 },
    "padding_px": { "top": 8, "right": 20, "bottom": 8, "left": 20 },
    "text_color": "#FFFFFF",
    "text_case": "uppercase",
    "font_family": "DejaVu Sans",
    "font_size_px": 30,
    "letter_spacing": 0,
    "line_height": 1.2,
    "text_template": "{name}",
    "secondary_text": { "enabled": false, "template": "{distance}", "color": "#D0B0F5" },
    "show_distance_as_secondary": false
  },

  "property_pin": {
    "mode": "teardrop_plain",
    "size_px": 130,
    "fill_color": "#6B3E99",
    "stroke_color": "#FFFFFF",
    "stroke_width_px": 4,
    "content": { "type": "none" },
    "address_label": { "enabled": false }
  },

  "boundary": {
    "enabled": false,
    "line": {
      "style": "dashed", "width_px": 5, "color": "#6B3E99", "corner_radius_px": 0,
      "shadow": { "enabled": true, "color": "#000000", "offset_x_px": 0, "offset_y_px": 4, "blur_px": 8 }
    },
    "exterior_treatment": {
      "blur_enabled": true, "blur_strength_px": 15,
      "darken_factor": 0.7, "hue_shift_degrees": 0,
      "saturation_factor": 0.8, "lightness_factor": 1.0
    },
    "side_measurements": {
      "enabled": true, "unit": "metres", "decimals": 1, "position": "outside",
      "text_color": "#FFFFFF", "text_outline_color": "#4A2A7A", "text_outline_width_px": 3,
      "font_size_px": 28, "font_family": "DejaVu Sans"
    },
    "sqm_total": {
      "enabled": true, "text_template": "{sqm} sqm approx", "position": "centroid",
      "text_color": "#FFFFFF", "bg_color": "#4A2A7A", "font_size_px": 60,
      "shadow": { "enabled": false }
    },
    "address_overlay": { "enabled": false, "position": "below_sqm" }
  },

  "poi_selection": {
    "radius_m": 1500, "max_pins_per_shot": 6, "min_separation_px": 220,
    "curation": "auto"
  },

  "branding_ribbon": { "enabled": false, "position": "none" },

  "output_variants": [
    { "name": "mls_web", "format": "JPEG", "quality": 88, "target_width_px": 2400,
      "aspect": "preserve", "max_bytes": 4000000, "color_profile": "sRGB" }
  ]
}
