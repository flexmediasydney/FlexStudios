{
  "theme_name": "Classic Red Bar",
  "version": "1.0",
  "inherits_from": null,

  "anchor_line": {
    "shape": "thick_bar",
    "width_px": 14,
    "color": "#E13A3A",
    "opacity": 1.0,
    "min_length_px": 40,
    "max_length_px": 220,
    "flip_below_target_threshold_px": 80,
    "end_marker": { "shape": "none" }
  },

  "poi_label": {
    "shape": "rectangle",
    "corner_radius_px": 0,
    "fill": "#E13A3A",
    "border": { "color": null, "width_px": 0 },
    "padding_px": { "top": 10, "right": 22, "bottom": 10, "left": 22 },
    "text_color": "#FFFFFF",
    "text_case": "uppercase",
    "font_family": "DejaVu Sans",
    "font_size_px": 36,
    "letter_spacing": 0,
    "line_height": 1.2,
    "text_template": "{name}",
    "secondary_text": { "enabled": false, "template": "{distance}", "color": "#FFCCCC" },
    "show_distance_as_secondary": false
  },

  "property_pin": {
    "mode": "pill_with_address",
    "size_px": 80,
    "fill_color": "#FFFFFF",
    "stroke_color": "#FFFFFF",
    "stroke_width_px": 0,
    "content": {
      "type": "text",
      "text": "6/3 SILVER ST",
      "text_color": "#E13A3A",
      "text_size_px": 34
    },
    "address_label": { "enabled": false }
  },

  "boundary": {
    "enabled": false,
    "line": {
      "style": "solid", "width_px": 6, "color": "#E13A3A", "corner_radius_px": 0,
      "shadow": { "enabled": true, "color": "#000000", "offset_x_px": 0, "offset_y_px": 4, "blur_px": 6 }
    },
    "exterior_treatment": {
      "blur_enabled": false, "blur_strength_px": 0,
      "darken_factor": 1.0, "hue_shift_degrees": 0,
      "saturation_factor": 1.0, "lightness_factor": 1.0
    },
    "side_measurements": {
      "enabled": true, "unit": "metres", "decimals": 1, "position": "outside",
      "text_color": "#FFFFFF", "text_outline_color": "#E13A3A", "text_outline_width_px": 3,
      "font_size_px": 28, "font_family": "DejaVu Sans"
    },
    "sqm_total": {
      "enabled": true, "text_template": "{sqm} sqm approx", "position": "centroid",
      "text_color": "#FFFFFF", "bg_color": "#E13A3A", "font_size_px": 60,
      "shadow": { "enabled": false }
    },
    "address_overlay": { "enabled": false, "position": "below_sqm" }
  },

  "poi_selection": {
    "radius_m": 1500, "max_pins_per_shot": 6, "min_separation_px": 220,
    "curation": "auto"
  },

  "branding_ribbon": { "enabled": false, "position": "none" },

  "output_variants": [
    { "name": "mls_web", "format": "JPEG", "quality": 88, "target_width_px": 2400,
      "aspect": "preserve", "max_bytes": 4000000, "color_profile": "sRGB" }
  ]
}
