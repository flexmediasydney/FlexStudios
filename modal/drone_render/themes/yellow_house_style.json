{
  "theme_name": "Yellow House",
  "version": "1.0",
  "inherits_from": null,

  "anchor_line": {
    "shape": "thin",
    "width_px": 3,
    "color": "#FFC72C",
    "opacity": 1.0,
    "min_length_px": 40,
    "max_length_px": 220,
    "flip_below_target_threshold_px": 80,
    "end_marker": {
      "shape": "dot",
      "size_px": 16,
      "fill_color": "#FFC72C",
      "stroke_color": "#FFC72C",
      "stroke_width_px": 0
    }
  },

  "poi_label": {
    "shape": "rectangle",
    "corner_radius_px": 0,
    "fill": "#0A0A0A",
    "border": { "color": "#FFC72C", "width_px": 0 },
    "padding_px": { "top": 10, "right": 20, "bottom": 10, "left": 20 },
    "text_color": "#FFFFFF",
    "text_case": "uppercase",
    "font_family": "DejaVu Sans",
    "font_size_px": 32,
    "letter_spacing": 0,
    "line_height": 1.2,
    "text_template": "{name}",
    "secondary_text": { "enabled": false, "template": "{distance}", "color": "#FFC72C" },
    "show_distance_as_secondary": false
  },

  "property_pin": {
    "mode": "teardrop_with_icon",
    "size_px": 150,
    "fill_color": "#FFC72C",
    "stroke_color": "#FFFFFF",
    "stroke_width_px": 0,
    "content": {
      "type": "icon",
      "icon_name": "home",
      "icon_color": "#0A0A0A",
      "text_color": "#0A0A0A"
    },
    "address_label": { "enabled": false }
  },

  "boundary": {
    "enabled": false,
    "line": {
      "style": "solid", "width_px": 6, "color": "#FFC72C", "corner_radius_px": 0,
      "shadow": { "enabled": true, "color": "#000000", "offset_x_px": 0, "offset_y_px": 4, "blur_px": 6 }
    },
    "exterior_treatment": {
      "blur_enabled": false, "blur_strength_px": 0,
      "darken_factor": 0.9, "hue_shift_degrees": 0,
      "saturation_factor": 0.95, "lightness_factor": 1.0
    },
    "side_measurements": {
      "enabled": true, "unit": "metres", "decimals": 1, "position": "outside",
      "text_color": "#FFFFFF", "text_outline_color": "#0A0A0A", "text_outline_width_px": 3,
      "font_size_px": 28, "font_family": "DejaVu Sans"
    },
    "sqm_total": {
      "enabled": true, "text_template": "{sqm} sqm approx", "position": "centroid",
      "text_color": "#0A0A0A", "bg_color": "#FFC72C", "font_size_px": 60,
      "shadow": { "enabled": false }
    },
    "address_overlay": { "enabled": false, "position": "below_sqm" }
  },

  "poi_selection": {
    "radius_m": 1500, "max_pins_per_shot": 6, "min_separation_px": 220,
    "curation": "auto"
  },

  "branding_ribbon": { "enabled": false, "position": "none" },

  "output_variants": [
    { "name": "mls_web", "format": "JPEG", "quality": 88, "target_width_px": 2400,
      "aspect": "preserve", "max_bytes": 4000000, "color_profile": "sRGB" }
  ]
}
